# Copy this file to .env.local and fill in your values
# Get your Anthropic API key at https://console.anthropic.com
# NOTE: ANTHROPIC_API_KEY is only needed for the /api/validate-key route.
# All other Claude calls use the user's own key passed via x-api-key header.

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — get these from your project's Settings → API page
# https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
